XUI_DEBUG=true
XUI_DB_FOLDER=x-ui
XUI_LOG_FOLDER=x-ui
XUI_BIN_FOLDER=x-ui

# 服务注册中心（可选）。逗号分隔多个根 URL，会覆盖配置文件。
# XUI_REGISTRY_NODES=http://10.0.0.1:8080,http://10.0.0.2:8080

# 注册中心列表文件路径（可选）。每行一个 URL，# 开头为注释。
# 未设置时使用 {XUI_DB_FOLDER}/registry_nodes；仍不存在则用内置默认。
# XUI_REGISTRY_NODES_FILE=/etc/x-ui/registry_nodes